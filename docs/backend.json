
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Extended user profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string" },
        "avatar": { "type": "string" },
        "bio": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "author", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Post": {
      "title": "Post",
      "description": "A blog article",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "published": { "type": "boolean" },
        "featured": { "type": "boolean" },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Comment": {
      "title": "Comment",
      "description": "A threaded user comment",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userAvatar": { "type": "string" },
        "content": { "type": "string" },
        "parentId": { "type": "string" },
        "likes": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Reaction": {
      "title": "Reaction",
      "description": "User emoji reaction to a post",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["like", "love", "fire", "mindblown", "rocket", "genius"] }
      }
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Blog articles"
    },
    "/posts/{postId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Threaded comments for a post"
    },
    "/posts/{postId}/reactions/{userId}": {
      "schema": "Reaction",
      "description": "User reactions to posts"
    }
  }
}
