{
  "entities": {
    "User": {
      "title": "User",
      "description": "Production user profile with role-based attributes",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string" },
        "avatar": { "type": "string" },
        "bio": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "author", "user", "staff"] },
        "followers": { "type": "number" },
        "following": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Post": {
      "title": "Post",
      "description": "Fully interactive blog article",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "published": { "type": "boolean" },
        "featured": { "type": "boolean" },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Comment": {
      "title": "Comment",
      "description": "Threaded community comment",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userAvatar": { "type": "string" },
        "content": { "type": "string" },
        "parentId": { "type": "string" },
        "likes": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Reaction": {
      "title": "Reaction",
      "description": "Emoji reaction record",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["like", "love", "fire", "mindblown", "rocket", "genius"] }
      }
    },
    "Product": {
      "title": "Product",
      "description": "Marketplace item",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "stock": { "type": "number" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "Customer order history",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google", "github", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Blog articles"
    },
    "/posts/{postId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Post discussions"
    },
    "/posts/{postId}/reactions/{userId}": {
      "schema": "Reaction",
      "description": "User reactions"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Store inventory"
    },
    "/users/{userId}/cart/{productId}": {
      "schema": "object",
      "description": "Individual user cart items"
    },
    "/users/{userId}/orders/{orderId}": {
      "schema": "Order",
      "description": "User order records"
    }
  }
}
